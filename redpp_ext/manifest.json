{
  "manifest_version": 3,
  "name": "RedPP",
  "version": "0.2.1",
  "description": "What is this osu! map worth at <acc>% with <mods>?",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "RedPP",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://osu.ppy.sh/*",
    "https://assets.ppy.sh/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "redpp@r3dwolfie",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
